{
  "name": "browser-use-lite",
  "version": "0.1.0",
  "description": "轻量级AI浏览器自动化代理，零配置启动",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "browser-use-lite": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cli": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["browser", "automation", "ai", "agent", "puppeteer", "llm"],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "commander": "^12.1.0",
    "puppeteer": "^23.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "README.zh-TW.md",
    "LICENSE",
    "assets"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
